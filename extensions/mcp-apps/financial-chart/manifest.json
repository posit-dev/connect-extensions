{
  "version": 1,
  "locale": "en_US.UTF-8",
  "metadata": {
    "appmode": "python-fastapi",
    "entrypoint": "main:app"
  },
  "python": {
    "version": "3.11",
    "package_manager": {
      "name": "pip",
      "version": "24.0",
      "package_file": "requirements.txt"
    }
  },
  "environment": {
    "python": {
      "requires": ">=3.11"
    }
  },
  "mcp": {
    "enabled": true
  },
  "extension": {
    "name": "financial-chart",
    "title": "Financial Chart MCP App",
    "description": "Interactive financial time series chart demonstrating the MCP Apps pattern with FastMCP v3. Shows inline and file-based UI delivery, app-only tools, and AppBridge host communication.",
    "homepage": "https://github.com/posit-dev/connect-extensions/tree/main/extensions/mcp-apps/financial-chart",
    "category": "example",
    "tags": ["python", "fastapi", "mcp"],
    "minimumConnectVersion": "2026.06.0",
    "version": "0.1.0"
  }
}
