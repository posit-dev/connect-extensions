{
  "version": 1,
  "locale": "en_US.UTF-8",
  "metadata": {
    "appmode": "quarto-static"
  },
  "extension": {
    "name": "script-python",
    "title": "Python: Scheduled Script",
    "description": "A Python script, scheduled to run on Connect, that imports and transforms data, saves the results as downloadable JSON and CSV files, and emails them on every run. A starting point for any recurring data job; swap in your own data source.",
    "homepage": "https://github.com/posit-dev/connect-extensions/tree/main/extensions/script-python",
    "category": "example",
    "minimumConnectVersion": "2025.04.0",
    "version": "1.0.3"
  },
  "environment": {
    "python": {
      "requires": "~=3.9"
    },
    "quarto": {
      "requires": "~=1.4"
    }
  },
  "quarto": {
    "version": "1.4.557",
    "engines": [
      "jupyter"
    ]
  },
  "python": {
    "version": "3.9.6",
    "package_manager": {
      "name": "pip",
      "version": "23.0.1",
      "package_file": "requirements.txt"
    }
  },
  "files": {
